---
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/layout/Nav.astro';
import Footer from '@components/layout/Footer.astro';
---
<BaseLayout
  title="AutoClub — Projekt · Kacper Stolarczyk"
  description="Platforma rezerwacji luksusowych samochodów z systemem membership. End-to-end UX/UI — badania, design system, interaktywny prototyp."
  navTheme="light"
>
  <Nav />
  <style>
    :root {
      --ac-blue:   #2563EB;
      --ac-blue-l: #3B82F6;
      --ac-orange: #F97316;
      --ac-dark:   #0F1E3C;
      --ac-bg:     #F8FAFC;
      --ac-text:   #1E293B;
      --ac-muted:  #64748B;
      --ac-border: rgba(37,99,235,0.14);
      --ac-glass:  rgba(255,255,255,0.60);
      --ac-blur:   saturate(180%) blur(20px);
    }

    .w { max-width: 1160px; margin: 0 auto; padding: 0 48px; }

    /* HERO */
    .hero {
      min-height: 100vh; padding-top: 60px;
      position: relative; overflow: hidden;
      display: flex; align-items: center;
      background: radial-gradient(ellipse 80% 70% at 65% 40%, rgba(59,130,246,0.18) 0%, transparent 65%),
                  radial-gradient(ellipse 50% 50% at 10% 85%, rgba(249,115,22,0.10) 0%, transparent 60%),
                  #F8FAFC;
    }
    .hero-orb {
      position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none;
    }
    .hero-orb-1 { width: 560px; height: 560px; top: -80px; right: -60px;
      background: radial-gradient(circle, rgba(59,130,246,0.20), transparent 70%); }
    .hero-orb-2 { width: 400px; height: 400px; bottom: 0; left: -100px;
      background: radial-gradient(circle, rgba(249,115,22,0.12), transparent 70%); }

    .hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; padding: 80px 0; }

    .back {
      display: inline-flex; align-items: center; gap: 8px; margin-bottom: 32px;
      font-size: 11px; letter-spacing: .16em; text-transform: uppercase;
      color: var(--ac-muted); transition: color .2s;
    }
    .back:hover { color: var(--ac-blue); }

    .badge {
      display: inline-flex; align-items: center; gap: 8px; margin-bottom: 20px;
      padding: 5px 14px; border-radius: 99px; font-size: 11px; font-weight: 600;
      color: var(--ac-blue); background: rgba(37,99,235,0.10); border: 1px solid rgba(37,99,235,0.20);
    }
    .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ac-blue); }

    h1 {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(44px, 5vw, 80px); line-height: .95;
      letter-spacing: -.04em; color: var(--ac-text); margin-bottom: 20px;
    }
    h1 em { color: var(--ac-blue); font-style: normal; }
    h1 strong { color: var(--ac-orange); font-weight: 900; }

    .hero-sub { font-size: 15px; color: var(--ac-muted); max-width: 440px; line-height: 1.75; margin-bottom: 40px; }

    .hero-stats {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
      background: var(--ac-border); border: 1px solid var(--ac-border);
    }
    .hs { padding: 20px 24px; background: var(--ac-glass); backdrop-filter: var(--ac-blur); }
    .hs-n { font-family: var(--font-display); font-weight: 900; font-size: 28px; color: var(--ac-blue); line-height: 1; }
    .hs-l { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--ac-muted); margin-top: 4px; }

    /* GLASS CARD (hero right) */
    .hero-card {
      background: var(--ac-glass); backdrop-filter: var(--ac-blur);
      border: 1px solid rgba(255,255,255,0.70);
      box-shadow: 0 24px 64px rgba(15,30,60,0.12);
      border-radius: 24px; padding: 32px; position: relative; overflow: hidden;
    }
    .hero-card::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(37,99,235,0.05) 0%, rgba(249,115,22,0.03) 100%);
      border-radius: inherit;
    }
    .car-badge {
      display: inline-flex; align-items: center; gap: 6px; margin-bottom: 20px;
      font-size: 10px; letter-spacing: .16em; text-transform: uppercase; font-weight: 600;
      color: var(--ac-orange);
    }
    .car-name { font-family: var(--font-display); font-weight: 900; font-size: 24px; color: var(--ac-text); margin-bottom: 4px; letter-spacing: -.02em; }
    .car-sub { font-size: 12px; color: var(--ac-muted); margin-bottom: 24px; }
    .car-specs { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 24px; }
    .spec { background: rgba(37,99,235,0.06); border: 1px solid var(--ac-border); border-radius: 12px; padding: 12px; text-align: center; }
    .spec-v { font-family: var(--font-display); font-weight: 800; font-size: 16px; color: var(--ac-text); }
    .spec-l { font-size: 9px; letter-spacing: .12em; text-transform: uppercase; color: var(--ac-muted); margin-top: 2px; }
    .tier-strip { display: flex; gap: 8px; }
    .tier { flex: 1; padding: 8px; border-radius: 10px; border: 1.5px solid transparent; text-align: center; font-size: 10px; font-weight: 700; letter-spacing: .08em; }
    .tier.silver { background: rgba(148,163,184,0.10); color: #94A3B8; border-color: rgba(148,163,184,0.25); }
    .tier.gold   { background: rgba(249,115,22,0.08); color: var(--ac-orange); border-color: rgba(249,115,22,0.30); }
    .tier.plat   { background: rgba(37,99,235,0.08); color: var(--ac-blue); border-color: rgba(37,99,235,0.30); }
    .status-bar { display: flex; align-items: center; gap: 8px; margin-top: 16px; font-size: 11px; color: var(--ac-muted); }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; background: #22C55E; flex-shrink: 0; }

    /* SECTIONS */
    .section { padding: 96px 0; border-top: 1px solid var(--ac-border); }
    .section.dark { background: var(--ac-dark); border-top: none; }
    .sec-label { font-size: 9px; letter-spacing: .22em; text-transform: uppercase; color: var(--ac-blue); margin-bottom: 14px; font-weight: 600; }
    .sec-h { font-family: var(--font-display); font-weight: 900; font-size: clamp(26px, 3vw, 44px); letter-spacing: -.03em; color: var(--ac-text); margin-bottom: 12px; }
    .sec-h em { color: var(--ac-blue); font-style: normal; }
    .sec-h.light { color: #fff; }
    .sec-lead { font-size: 14px; color: var(--ac-muted); line-height: 1.8; max-width: 520px; margin-bottom: 48px; }
    .sec-lead.light { color: rgba(255,255,255,0.55); }

    /* META ROW */
    .meta { display: grid; grid-template-columns: repeat(4,1fr); border: 1px solid var(--ac-border); }
    .meta-cell { padding: 28px 32px; border-right: 1px solid var(--ac-border); background: var(--ac-glass); backdrop-filter: var(--ac-blur); }
    .meta-cell:last-child { border-right: none; }
    .meta-l { font-size: 9px; letter-spacing: .18em; text-transform: uppercase; color: var(--ac-muted); margin-bottom: 8px; }
    .meta-v { font-size: 13px; font-weight: 600; color: var(--ac-text); line-height: 1.4; }
    .meta-s { font-size: 11px; color: var(--ac-muted); font-weight: 400; }

    /* TIER CARDS */
    .tiers { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--ac-border); border: 1px solid var(--ac-border); }
    .tier-card { padding: 36px 28px; background: #fff; position: relative; overflow: hidden; }
    .tier-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; }
    .tier-card.silver::before { background: linear-gradient(90deg, #94A3B8, #CBD5E1); }
    .tier-card.gold::before   { background: linear-gradient(90deg, var(--ac-orange), #FBBF24); }
    .tier-card.plat::before   { background: linear-gradient(90deg, var(--ac-blue), var(--ac-blue-l)); }
    .tier-name { font-family: var(--font-display); font-weight: 900; font-size: 20px; letter-spacing: -.02em; margin-bottom: 4px; }
    .tier-card.silver .tier-name { color: #94A3B8; }
    .tier-card.gold   .tier-name { color: var(--ac-orange); }
    .tier-card.plat   .tier-name { color: var(--ac-blue); }
    .tier-price { font-family: var(--font-display); font-weight: 900; font-size: 40px; color: var(--ac-text); line-height: 1; margin: 16px 0 4px; }
    .tier-per { font-size: 12px; color: var(--ac-muted); margin-bottom: 20px; }
    .tier-feat { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .tier-feat li { font-size: 12px; color: var(--ac-text); display: flex; align-items: center; gap: 8px; }
    .tier-feat li::before { content: ''; width: 16px; height: 16px; border-radius: 50%; flex-shrink: 0; }
    .tier-card.silver .tier-feat li::before { background: rgba(148,163,184,0.15); border: 1px solid #94A3B8; }
    .tier-card.gold   .tier-feat li::before { background: rgba(249,115,22,0.12); border: 1px solid var(--ac-orange); }
    .tier-card.plat   .tier-feat li::before { background: rgba(37,99,235,0.12); border: 1px solid var(--ac-blue); }

    /* UX DECISIONS */
    .decisions { display: grid; grid-template-columns: repeat(2,1fr); gap: 1px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.10); }
    .dec { padding: 32px 28px; }
    .dec-n { font-size: 10px; letter-spacing: .2em; color: rgba(255,255,255,.25); margin-bottom: 8px; font-weight: 600; }
    .dec-title { font-family: var(--font-display); font-weight: 800; font-size: 16px; color: #fff; margin-bottom: 8px; }
    .dec-body { font-size: 12px; color: rgba(255,255,255,.45); line-height: 1.7; }

    /* RESULTS */
    .results { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--ac-border); border: 1px solid var(--ac-border); }
    .res { padding: 32px 24px; background: rgba(37,99,235,0.04); text-align: center; }
    .res-n { font-family: var(--font-display); font-weight: 900; font-size: 40px; color: var(--ac-blue); line-height: 1; }
    .res-l { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--ac-muted); margin-top: 6px; }

    /* CTA */
    .cta-band {
      background: linear-gradient(135deg, var(--ac-dark) 0%, #162040 100%);
      padding: 80px 48px; display: flex; align-items: center; justify-content: space-between; gap: 40px;
    }
    .cta-label { font-size: 9px; letter-spacing: .2em; text-transform: uppercase; color: rgba(255,255,255,.3); margin-bottom: 12px; }
    .cta-title { font-family: var(--font-display); font-weight: 900; font-size: clamp(22px, 2.8vw, 40px); letter-spacing: -.03em; color: #fff; line-height: 1.15; }
    .cta-title em { color: var(--ac-orange); font-style: normal; }
    .cta-btn { font-size: 11px; letter-spacing: .14em; text-transform: uppercase; white-space: nowrap; padding: 16px 36px; background: linear-gradient(135deg, var(--ac-orange), #EA6A0A); color: #fff; border: none; box-shadow: 0 8px 24px rgba(249,115,22,.40); transition: transform .2s, box-shadow .2s; flex-shrink: 0; font-weight: 700; }
    .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(249,115,22,.50); }

    /* NEXT */
    .next { padding: 72px 0; text-align: center; border-top: 1px solid var(--ac-border); }
    .next-l { font-size: 9px; letter-spacing: .22em; text-transform: uppercase; color: var(--ac-muted); margin-bottom: 14px; }
    .next-a { font-family: var(--font-display); font-weight: 900; font-size: clamp(24px, 3vw, 44px); letter-spacing: -.03em; color: var(--ac-text); transition: color .2s; }
    .next-a:hover { color: var(--ac-blue); }

    /* REVEAL */
    .r { opacity: 0; transform: translateY(20px); transition: opacity .65s cubic-bezier(.22,.61,.36,1), transform .65s cubic-bezier(.22,.61,.36,1); }
    .r.v { opacity: 1; transform: none; }
    .d1 { transition-delay: .1s; } .d2 { transition-delay: .2s; } .d3 { transition-delay: .3s; }

    @media (max-width: 1024px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-card { display: none; }
      .meta { grid-template-columns: 1fr 1fr; }
      .meta-cell:nth-child(2) { border-right: none; }
      .meta-cell:nth-child(1), .meta-cell:nth-child(2) { border-bottom: 1px solid var(--ac-border); }
      .tiers { grid-template-columns: 1fr; }
      .decisions { grid-template-columns: 1fr; }
      .results { grid-template-columns: repeat(2,1fr); }
      .cta-band { flex-direction: column; text-align: center; }
      .w { padding: 0 24px; }
    }
    @media (max-width: 600px) {
      .meta { grid-template-columns: 1fr; }
      .meta-cell { border-right: none !important; border-bottom: 1px solid var(--ac-border); }
      .meta-cell:last-child { border-bottom: none; }
      .hero-stats { grid-template-columns: repeat(2,1fr); }
      .results { grid-template-columns: 1fr 1fr; }
      .cta-band { padding: 56px 20px; }
      .w { padding: 0 20px; }
    }
  </style>

  <div>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="w" style="width:100%">
        <div class="hero-inner">
          <div>
            <a href="/#portfolio" class="back">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
              Portfolio
            </a>
            <div class="badge"><span class="badge-dot"></span> SaaS · E-commerce UX · 2024</div>
            <h1>Auto<em>Club</em><br><strong>Platform</strong></h1>
            <p class="hero-sub">Platforma rezerwacji luksusowych samochodów z systemem membership Silver / Gold / Platinum. End-to-end UX/UI — od badań przez design system po interaktywny prototyp.</p>
            <div class="hero-stats">
              <div class="hs"><div class="hs-n">-40%</div><div class="hs-l">czas rezerwacji</div></div>
              <div class="hs"><div class="hs-n">94%</div><div class="hs-l">task completion</div></div>
              <div class="hs"><div class="hs-n">3</div><div class="hs-l">poziomy membership</div></div>
              <div class="hs"><div class="hs-n">NPS 71</div><div class="hs-l">wynik prototypu</div></div>
            </div>
          </div>

          <!-- GLASS MOCKUP CARD -->
          <div class="hero-card">
            <div class="car-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--ac-orange)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Dostępny · PLATINUM
            </div>
            <div class="car-name">Porsche 911 Turbo S</div>
            <div class="car-sub">Cabrio · 650 KM · 2024</div>
            <div class="car-specs">
              <div class="spec"><div class="spec-v">2.7s</div><div class="spec-l">0–100</div></div>
              <div class="spec"><div class="spec-v">330</div><div class="spec-l">km/h max</div></div>
              <div class="spec"><div class="spec-v">650</div><div class="spec-l">KM</div></div>
            </div>
            <div class="tier-strip">
              <div class="tier silver">SILVER</div>
              <div class="tier gold">GOLD</div>
              <div class="tier plat" style="border-color:var(--ac-blue);background:rgba(37,99,235,0.15)">PLATINUM ✓</div>
            </div>
            <div class="status-bar">
              <div class="status-dot"></div>
              Dostępny od zaraz · 3 sztuki
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- META -->
    <div class="meta r">
      <div class="meta-cell"><div class="meta-l">Klient</div><div class="meta-v">AutoClub Sp. z o.o.</div><div class="meta-s">Wypożyczalnia premium, Warszawa</div></div>
      <div class="meta-cell"><div class="meta-l">Moja rola</div><div class="meta-v">Lead UX/UI Designer</div><div class="meta-s">Badania · Design System · Prototyp</div></div>
      <div class="meta-cell"><div class="meta-l">Zakres</div><div class="meta-v">SaaS · E-commerce UX</div><div class="meta-s">Dashboard · Membership Flow</div></div>
      <div class="meta-cell"><div class="meta-l">Czas realizacji</div><div class="meta-v">10 tygodni</div><div class="meta-s">End-to-end</div></div>
    </div>

    <!-- MEMBERSHIP TIERS -->
    <section class="section">
      <div class="w">
        <div class="r">
          <div class="sec-label">01 — System membership</div>
          <h2 class="sec-h">Trzy poziomy, <em>jedno doświadczenie</em></h2>
          <p class="sec-lead">Każdy tier ma inny ton komunikacji, dostęp do floty i zestaw benefitów — ale spójny język wizualny. Różnicowanie przez kolor i typografię, nie przez osobne layouty.</p>
        </div>
        <div class="tiers r d1">
          <div class="tier-card silver">
            <div class="tier-name">Silver</div>
            <div style="font-size:11px;color:var(--ac-muted)">Dla nowych członków</div>
            <div class="tier-price">99 <span style="font-size:16px;font-weight:400">zł</span></div>
            <div class="tier-per">/miesiąc lub 79 zł przy planie rocznym</div>
            <ul class="tier-feat">
              <li>Dostęp do floty podstawowej (8 modeli)</li>
              <li>2 rezerwacje miesięcznie</li>
              <li>Standard insurance</li>
              <li>24/7 support chat</li>
            </ul>
          </div>
          <div class="tier-card gold">
            <div class="tier-name">Gold</div>
            <div style="font-size:11px;color:var(--ac-muted)">Dla regularnych klientów</div>
            <div class="tier-price">199 <span style="font-size:16px;font-weight:400">zł</span></div>
            <div class="tier-per">/miesiąc lub 159 zł przy planie rocznym</div>
            <ul class="tier-feat">
              <li>Pełna flota (12+ modeli)</li>
              <li>5 rezerwacji miesięcznie</li>
              <li>Premium insurance + GPS</li>
              <li>Priorytetowe wsparcie</li>
              <li>Bezpłatna dostawa pojazdu</li>
            </ul>
          </div>
          <div class="tier-card plat">
            <div class="tier-name">Platinum</div>
            <div style="font-size:11px;color:var(--ac-muted)">Dla wymagających</div>
            <div class="tier-price">399 <span style="font-size:16px;font-weight:400">zł</span></div>
            <div class="tier-per">/miesiąc lub 319 zł przy planie rocznym</div>
            <ul class="tier-feat">
              <li>Ekskluzywna flota (wszystkie modele)</li>
              <li>Nieograniczone rezerwacje</li>
              <li>VIP concierge 24/7</li>
              <li>Dedykowany opiekun klienta</li>
              <li>Dostęp do wydarzeń zamkniętych</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- UX DECISIONS — dark section -->
    <section class="section dark">
      <div class="w">
        <div class="r">
          <div class="sec-label" style="color:var(--ac-orange)">02 — Kluczowe decyzje UX</div>
          <h2 class="sec-h light">Cztery decyzje, <em style="color:var(--ac-blue-l)">które zmieniły wyniki</em></h2>
          <p class="sec-lead light">Każda decyzja poprzedzona analizą danych z badań i A/B testów na istniejących przepływach.</p>
        </div>
        <div class="decisions r d1">
          <div class="dec">
            <div class="dec-n">01</div>
            <div class="dec-title">Booking w 3 krokach</div>
            <div class="dec-body">Stary flow miał 11 kroków — zbędne pytania o preferencje odkładaliśmy na profil. Wyszukiwarka z datami jako główny CTA, reszta opcjonalna. Task completion: 34% → 94%.</div>
          </div>
          <div class="dec">
            <div class="dec-n">02</div>
            <div class="dec-title">Real-time status floty</div>
            <div class="dec-body">Dostępny / Limitowany / Zarezerwowany / Wkrótce — żywy stan zamiast statycznej listy. Użytkownicy rezerwują szybciej gdy widzą ograniczoną dostępność.</div>
          </div>
          <div class="dec">
            <div class="dec-n">03</div>
            <div class="dec-title">Tier badge w każdym kontekście</div>
            <div class="dec-body">Status membership widoczny w nav, kartach floty i profilu — poczucie przynależności do ekskluzywnego klubu na każdym kroku, nie tylko na stronie cennika.</div>
          </div>
          <div class="dec">
            <div class="dec-n">04</div>
            <div class="dec-title">Billing toggle z animacją oszczędności</div>
            <div class="dec-body">Przełącznik miesięczny/roczny z animowaną kalkulacją oszczędności (do 960 zł/rok) i toast notification — konwersja na plany roczne wzrosła o 28%.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section class="section">
      <div class="w">
        <div class="r">
          <div class="sec-label">03 — Wyniki</div>
          <h2 class="sec-h">Prototyp <em>przetestowany</em> z 18 użytkownikami</h2>
          <p class="sec-lead">Mieszanka nowych i powracających klientów premium. Sesje moderowane + testy niemodernowane na Maze.</p>
        </div>
        <div class="results r d1">
          <div class="res"><div class="res-n">-40%</div><div class="res-l">czas do rezerwacji</div></div>
          <div class="res"><div class="res-n">94%</div><div class="res-l">task completion</div></div>
          <div class="res"><div class="res-n">NPS 71</div><div class="res-l">wynik prototypu</div></div>
          <div class="res"><div class="res-n">+28%</div><div class="res-l">wybór planu rocznego</div></div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-band">
      <div>
        <div class="cta-label">Chcesz zobaczyć klikalne demo?</div>
