---
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/layout/Nav.astro';
import Footer from '@components/layout/Footer.astro';
---

<BaseLayout
  title="QL&Joy Studio — Case Study · Kacper Stolarczyk"
  description="Kompleksowy projekt brandingowy — od namingu przez identyfikację wizualną po wdrożenie sklepu WooCommerce dla polskiej marki premium dzianin kobiecych."
>
  <Nav />

  <style>
    /* ── QL&Joy brand colors (fixed, not theme-dependent) ── */
    :root {
      --rasp:   #E8006C;
      --plum:   #2D2250;
      --powder: #F2A7B3;
      --mauve:  #7B5EA7;
      --petal:  #F7C5D0;
    }

    /* Map system tokens → ql- aliases */
    .ql-wrap {
      --ql-bg:    var(--bg);
      --ql-bg-off: var(--bg2);
      --ql-fg:    var(--fg);
      --ql-fg-40: var(--fg-60);
      --ql-rule:  var(--border);
    }

    /* ── BASE ── */
    .ql-wrap { font-family: var(--font-body); }
    a { color: inherit; text-decoration: none; }

    /* ── HERO ── */
    .ql-hero {
      min-height: 100vh; padding-top: 60px;
      position: relative; overflow: hidden;
    }
    .ql-hero-bg {
      position: absolute; inset: 0; z-index: 0;
    }
    .ql-hero-bg img {
      width: 100%; height: 100%; object-fit: cover; object-position: center;
    }
    .ql-hero-bg::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,.55) 0%, rgba(0,0,0,.1) 30%, transparent 55%);
    }
    .ql-hero-left {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 0 56px 56px;
      z-index: 1;
    }
    .ql-hero-right { display: none; }

    .ql-hero-num {
      position: absolute; top: 56px; left: 56px;
      font-family: var(--font-display); font-weight: 900; font-size: 13px;
      color: rgba(255,255,255,.15); letter-spacing: .08em;
    }
    .ql-hero-eyebrow {
      font-size: 10px; letter-spacing: .28em; text-transform: uppercase;
      color: var(--powder); margin-bottom: 20px;
      display: flex; align-items: center; gap: 10px;
    }
    .ql-hero-eyebrow { color: rgba(255,255,255,.7); }
    .ql-hero-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--rasp); }
    .ql-hero-h1 {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(52px, 5.5vw, 88px); line-height: .95;
      letter-spacing: -.04em; color: #fff; margin-bottom: 28px;
    }
    .ql-hero-h1 em { color: var(--powder); font-weight: 300; font-style: normal; letter-spacing: .04em; }
    .ql-hero-sub {
      font-family: var(--font-display); font-weight: 300; font-size: 16px;
      color: rgba(255,255,255,.65); max-width: 360px; line-height: 1.6; margin-bottom: 48px;
    }
    .ql-hero-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 48px; }
    .ql-pill {
      font-size: 9px; letter-spacing: .18em; text-transform: uppercase;
      padding: 5px 14px; border: 1px solid rgba(255,255,255,.25); color: rgba(255,255,255,.5);
    }
    .ql-pill.on { border-color: var(--rasp); color: var(--powder); }
    .ql-hero-stats {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 1px; background: rgba(255,255,255,.1);
      max-width: 540px;
    }
    .ql-stat { padding: 20px 28px; background: rgba(0,0,0,.25); }
    .ql-stat-n { font-family: var(--font-display); font-weight: 900; font-size: 32px; color: #fff; line-height: 1; }
    .ql-stat-l { font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: rgba(255,255,255,.4); margin-top: 4px; }

    /* Back link */
    .ql-back {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 11px; letter-spacing: .16em; text-transform: uppercase;
      color: rgba(255,255,255,.35); transition: color .2s;
      position: absolute; top: 24px; left: 56px;
    }
    .ql-back:hover { color: rgba(255,255,255,.8); }

    /* ── SECTIONS ── */
    .ql-section { padding: 120px 0; border-top: 1px solid var(--ql-rule); background: var(--ql-bg); }
    .ql-section.off { background: var(--ql-bg-off); }
    .ql-container { max-width: 1160px; margin: 0 auto; padding: 0 48px; }
    .ql-sec-header { display: grid; grid-template-columns: 200px 1fr; gap: 48px; margin-bottom: 72px; align-items: start; }
    .ql-sec-num { font-family: var(--font-display); font-weight: 300; font-size: 12px; color: var(--ql-fg-40); padding-top: 8px; }
    .ql-sec-title { font-family: var(--font-display); font-weight: 900; font-size: clamp(32px,3.8vw,54px); line-height: 1; letter-spacing: -.03em; color: var(--ql-fg); }
    .ql-sec-title em { font-weight: 800; color: var(--rasp); font-style: normal; }
    .ql-sec-lead { font-size: 15px; color: var(--ql-fg-40); line-height: 1.8; max-width: 520px; margin-top: 12px; }

    /* ── NAMING ── */
    .ql-naming-grid {
      display: grid; grid-template-columns: repeat(4,1fr);
      border: 1px solid var(--ql-rule); margin-bottom: 48px;
    }
    .ql-ns {
      padding: 36px 28px; border-right: 1px solid var(--ql-rule);
      position: relative; transition: background .25s; 
    }
    .ql-ns:last-child { border-right: none; }
    .ql-ns:hover { background: var(--ql-bg-off); }
    .ql-ns-n {
      font-family: var(--font-display); font-weight: 900; font-size: 48px;
      line-height: 1; color: var(--ql-rule); margin-bottom: 16px; letter-spacing: -.03em;
    }
    .ql-ns-title { font-size: 12px; font-weight: 500; letter-spacing: .04em; margin-bottom: 8px; }
    .ql-ns-body { font-size: 12px; color: var(--ql-fg-40); line-height: 1.6; }
    .ql-ns-dot {
      position: absolute; top: 28px; right: 28px;
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--ql-rule); transition: background .25s;
    }
    .ql-ns:hover .ql-ns-dot { background: var(--rasp); }

    .ql-cloud {
      border: 1px solid var(--ql-rule); padding: 36px;
      display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
      background: var(--ql-bg-off);
    }
    .ql-chip {
      font-size: 11px; letter-spacing: .06em; padding: 6px 16px;
      border: 1px solid var(--border2); color: var(--fg-60);
      transition: all .2s; 
    }
    .ql-chip:hover { border-color: var(--fg); color: var(--fg); }
    .ql-chip.fin { border-color: var(--mauve); color: var(--mauve); }
    .ql-chip.pick { background: var(--plum); color: #fff; border-color: var(--plum); font-weight: 500; }
    .ql-cloud-more { font-size: 11px; color: var(--ql-fg-40); font-style: italic; padding: 6px 0; }

    /* ── BRANDING ── */
    .ql-iter-strip {
      display: grid; grid-template-columns: repeat(5,1fr);
      border: 1px solid var(--ql-rule); margin-bottom: 56px; overflow: hidden;
    }
    .ql-iter {
      aspect-ratio: 3/4; position: relative;
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 20px 16px; overflow: hidden; 
      transition: flex .4s ease;
    }
    .ql-iter-strip:hover .ql-iter { flex: .7; }
    .ql-iter-strip .ql-iter:hover { flex: 2; }
    .ql-iter-v { font-size: 8px; letter-spacing: .2em; text-transform: uppercase; color: rgba(255,255,255,.4); margin-bottom: 6px; }
    .ql-iter-name { font-family: var(--font-display); font-weight: 900; font-size: 13px; color: #fff; line-height: 1.2; }
    .ql-iter-sub { font-size: 10px; color: rgba(255,255,255,.4); margin-top: 3px; }
    .ql-iter.final::after {
      content: 'FINAL'; position: absolute; top: 14px; right: 14px;
      font-size: 8px; letter-spacing: .18em; background: var(--rasp);
      padding: 3px 8px; color: #fff;
    }

    .ql-palette {
      display: flex; height: 100px;
      border: 1px solid var(--ql-rule); overflow: hidden; margin-bottom: 48px;
    }
    .ql-swatch { flex: 1; display: flex; flex-direction: column; justify-content: flex-end; padding: 14px 16px; transition: flex .3s ease;  }
    .ql-palette:hover .ql-swatch { flex: .6; }
    .ql-palette .ql-swatch:hover { flex: 2.2; }
    .ql-sw-name { font-size: 10px; font-weight: 500; white-space: nowrap; overflow: hidden; }
    .ql-sw-hex { font-size: 9px; opacity: .6; font-family: monospace; }

    .ql-logo-row { display: grid; grid-template-columns: repeat(3,1fr); border: 1px solid var(--ql-rule); overflow: hidden; }
    .ql-logo-tile {
      aspect-ratio: 16/9; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 12px;
      border-right: 1px solid var(--ql-rule);
      position: relative; transition: opacity .2s;
    }
    .ql-logo-tile:last-child { border-right: none; }
    .ql-logo-tile:hover { opacity: .85; }
    .ql-lt-label { position: absolute; bottom: 12px; font-size: 8px; letter-spacing: .2em; text-transform: uppercase; opacity: .3; }
    .ql-wm {
      font-family: var(--font-display); font-weight: 900; font-size: 24px;
      letter-spacing: .03em; display: flex; align-items: center; gap: 2px;
    }
    .ql-amp { font-weight: 800; font-size: 1.15em; color: var(--rasp); margin: 0 2px; transform: translateY(.06em); display: inline-block; }
    .ql-ldots { display: flex; gap: 7px; }
    .ql-ld { width: 7px; height: 7px; border-radius: 50%; }

    /* ── QUOTE ── */
    .ql-quote-block {
      background: var(--plum); padding: 100px 48px;
      text-align: center; position: relative; overflow: hidden;
    }
    .ql-quote-block::before {
      content: '\201C'; font-family: var(--font-display); font-size: 360px; font-weight: 900;
      position: absolute; top: -80px; left: 50%; transform: translateX(-50%);
      color: rgba(255,255,255,.04); line-height: 1; pointer-events: none;
    }
    .ql-q-text {
      font-family: var(--font-display); font-weight: 300;
      font-size: clamp(22px,3.2vw,40px); color: #fff; line-height: 1.35;
      max-width: 820px; margin: 0 auto 24px; position: relative; z-index: 1;
    }
    .ql-q-attr { font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: rgba(255,255,255,.3); position: relative; z-index: 1; }

    /* ── UX ── */
    .ql-ux-cols {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1px; background: var(--ql-rule);
      border: 1px solid var(--ql-rule); margin-bottom: 56px;
    }
    .ql-ux-panel { background: var(--ql-bg); }
    .ql-decisions { display: flex; flex-direction: column; }
    .ql-dec {
      display: grid; grid-template-columns: 56px 1fr;
      padding: 24px 32px; border-bottom: 1px solid var(--ql-rule);
      transition: background .2s; 
    }
    .ql-dec:last-child { border-bottom: none; }
    .ql-dec:hover { background: var(--ql-bg-off); }
    .ql-dec-n { font-family: var(--font-display); font-weight: 900; font-size: 11px; color: var(--ql-fg-40); padding-top: 2px; }
    .ql-dec-title { font-size: 13px; font-weight: 500; margin-bottom: 4px; color: var(--ql-fg); }
    .ql-dec-body { font-size: 12px; color: var(--ql-fg-40); line-height: 1.6; }

    /* ── RESULTS ── */
    .ql-results-row {
      display: grid; grid-template-columns: repeat(4,1fr);
      border: 1px solid var(--ql-rule); margin-bottom: 56px;
    }
    .ql-res {
      padding: 40px 32px; border-right: 1px solid var(--ql-rule);
      transition: background .2s; 
    }
    .ql-res:last-child { border-right: none; }
    .ql-res:hover { background: var(--ql-bg-off); }
    .ql-res-n { font-family: var(--font-display); font-weight: 900; font-size: 48px; line-height: 1; letter-spacing: -.03em; margin-bottom: 6px; color: var(--ql-fg); }
    .ql-res-n sup { font-size: .45em; color: var(--rasp); vertical-align: super; }
    .ql-res-l { font-size: 11px; color: var(--ql-fg-40); letter-spacing: .06em; line-height: 1.5; }

    .ql-deliv-grid {
      display: grid; grid-template-columns: repeat(3,1fr);
      border: 1px solid var(--ql-rule);
    }
    .ql-deliv {
      padding: 28px 32px; border-right: 1px solid var(--ql-rule); border-bottom: 1px solid var(--ql-rule);
      display: flex; gap: 18px; align-items: flex-start;
      transition: background .2s; 
    }
    .ql-deliv:nth-child(3n) { border-right: none; }
    .ql-deliv:nth-last-child(-n+3) { border-bottom: none; }
    .ql-deliv:hover { background: var(--ql-bg-off); }
    .ql-deliv-icon { font-size: 20px; flex-shrink: 0; margin-top: 2px; }
    .ql-deliv-name { font-size: 13px; font-weight: 500; margin-bottom: 3px; color: var(--ql-fg); }
    .ql-deliv-desc { font-size: 11px; color: var(--ql-fg-40); line-height: 1.55; }

    /* ── CONTEXT ── */
    .ql-meta-row {
      display: grid; grid-template-columns: repeat(4,1fr);
      border-bottom: 1px solid var(--ql-rule); margin-bottom: 64px;
    }
    .ql-meta-cell {
      padding: 28px 32px; border-right: 1px solid var(--ql-rule);
    }
    .ql-meta-cell:last-child { border-right: none; }
    .ql-meta-label { font-size: 9px; letter-spacing: .2em; text-transform: uppercase; color: var(--ql-fg-40); margin-bottom: 8px; }
    .ql-meta-val { font-size: 14px; font-weight: 500; color: var(--ql-fg); line-height: 1.4; }

    .ql-challenge-block {
      border: 1px solid var(--ql-rule); padding: 48px;
      background: var(--ql-bg-off); margin-bottom: 48px; position: relative;
    }
    .ql-challenge-block::before {
      content: '?'; position: absolute; top: -20px; left: 40px;
      font-family: var(--font-display); font-weight: 900; font-size: 48px;
      color: var(--rasp); line-height: 1;
    }
    .ql-challenge-q {
      font-family: var(--font-display); font-weight: 300;
      font-size: clamp(18px,2.2vw,28px); color: var(--ql-fg);
      line-height: 1.45; max-width: 680px;
    }
    .ql-challenge-q em { color: var(--rasp); font-style: normal; font-weight: 600; }

    .ql-goals-row {
      display: grid; grid-template-columns: repeat(3,1fr);
      border: 1px solid var(--ql-rule);
    }
    .ql-goal {
      padding: 32px 28px; border-right: 1px solid var(--ql-rule);
      position: relative; overflow: hidden;
    }
    .ql-goal:last-child { border-right: none; }
    .ql-goal::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0;
      height: 2px; background: var(--rasp); transform: scaleX(0);
      transform-origin: left; transition: transform .35s;
    }
    .ql-goal:hover::after { transform: scaleX(1); }
    .ql-goal-tag {
      font-size: 9px; letter-spacing: .18em; text-transform: uppercase;
      color: var(--rasp); margin-bottom: 12px;
    }
    .ql-goal-title { font-weight: 600; font-size: 14px; margin-bottom: 8px; color: var(--ql-fg); }
    .ql-goal-body { font-size: 12px; color: var(--ql-fg-40); line-height: 1.65; }

    /* ── TYPOGRAPHY ── */
    .ql-type-grid {
      display: grid; grid-template-columns: repeat(2,1fr);
      border: 1px solid var(--ql-rule); margin-bottom: 48px;
    }
    .ql-type-cell {
      padding: 36px; border-right: 1px solid var(--ql-rule);
      border-bottom: 1px solid var(--ql-rule);
    }
    .ql-type-cell:nth-child(even) { border-right: none; }
    .ql-type-cell:nth-last-child(-n+2) { border-bottom: none; }
    .ql-type-meta { font-size: 9px; letter-spacing: .18em; text-transform: uppercase; color: var(--ql-fg-40); margin-bottom: 12px; }
    .ql-type-role { font-size: 10px; color: var(--mauve); margin-bottom: 16px; letter-spacing: .06em; }

    /* ── REFLECTION ── */
    .ql-refl-cols {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1px; background: var(--ql-rule);
      border: 1px solid var(--ql-rule); margin-bottom: 56px;
    }
    .ql-refl-panel { background: var(--ql-bg); padding: 48px; }
    .ql-refl-label {
      font-size: 9px; letter-spacing: .22em; text-transform: uppercase;
      margin-bottom: 28px; display: flex; align-items: center; gap: 10px;
    }
    .ql-refl-label.good { color: #00c97a; }
    .ql-refl-label.hard { color: var(--rasp); }
    .ql-refl-label::before { content: ''; width: 20px; height: 1px; background: currentColor; }
    .ql-refl-item {
      padding: 16px 0; border-bottom: 1px solid var(--ql-rule);
      font-size: 13px; color: var(--ql-fg-40); line-height: 1.65;
    }
    .ql-refl-item:last-child { border-bottom: none; padding-bottom: 0; }
    .ql-refl-item strong { color: var(--ql-fg); font-weight: 500; display: block; margin-bottom: 4px; }

    /* ── COMPETENCIES ── */
    .ql-skills-grid {
      display: grid; grid-template-columns: repeat(3,1fr);
      border: 1px solid var(--ql-rule);
    }
    .ql-skill {
      padding: 32px 28px; border-right: 1px solid var(--ql-rule);
      border-bottom: 1px solid var(--ql-rule);
      transition: background .2s;
    }
    .ql-skill:nth-child(3n) { border-right: none; }
    .ql-skill:nth-last-child(-n+3) { border-bottom: none; }
    .ql-skill:hover { background: var(--ql-bg-off); }
    .ql-skill-area {
      font-size: 9px; letter-spacing: .2em; text-transform: uppercase;
      color: var(--rasp); margin-bottom: 10px;
    }
    .ql-skill-title { font-weight: 600; font-size: 14px; color: var(--ql-fg); margin-bottom: 8px; }
    .ql-skill-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .ql-skill-tag {
      font-size: 10px; padding: 3px 10px;
      border: 1px solid var(--ql-rule); color: var(--ql-fg-40);
    }

    /* ── RESPONSIVE additions ── */
    @media (max-width: 1024px) {
      .ql-meta-row { grid-template-columns: 1fr 1fr; }
      .ql-goals-row { grid-template-columns: 1fr; }
      .ql-goal { border-right: none; border-bottom: 1px solid var(--ql-rule); }
      .ql-goal:last-child { border-bottom: none; }
      .ql-type-grid { grid-template-columns: 1fr; }
      .ql-type-cell { border-right: none; }
      .ql-refl-cols { grid-template-columns: 1fr; }
      .ql-skills-grid { grid-template-columns: 1fr 1fr; }
      .ql-skill:nth-child(3n) { border-right: 1px solid var(--ql-rule); }
      .ql-skill:nth-child(even) { border-right: none; }
      .ql-skill:nth-last-child(-n+3) { border-bottom: 1px solid var(--ql-rule); }
      .ql-skill:nth-last-child(-n+2) { border-bottom: none; }
    }
    @media (max-width: 640px) {
      .ql-meta-row { grid-template-columns: 1fr 1fr; }
      .ql-skills-grid { grid-template-columns: 1fr; }
      .ql-skill { border-right: none; }
      .ql-challenge-block { padding: 36px 24px; }
    }
    .ql-next { padding: 80px 0; border-top: 1px solid var(--ql-rule); text-align: center; background: var(--ql-bg); }
    .ql-next-label { font-size: 10px; letter-spacing: .22em; text-transform: uppercase; color: var(--ql-fg-40); margin-bottom: 16px; }
    .ql-next-link {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(28px,3.5vw,52px); letter-spacing: -.03em;
      color: var(--ql-fg); transition: color .2s; display: inline-block;
    }
    .ql-next-link:hover { color: var(--rasp); }

    /* ── REVEAL ── */
    .r { opacity: 0; transform: translateY(28px); transition: opacity .75s cubic-bezier(.22,.61,.36,1), transform .75s cubic-bezier(.22,.61,.36,1); }
    .r.v { opacity: 1; transform: none; }
    .r.d1 { transition-delay: .1s; } .r.d2 { transition-delay: .2s; } .r.d3 { transition-delay: .3s; }
    @keyframes ha-up { from { opacity:0; transform:translateY(22px); } to { opacity:1; transform:none; } }
    .ha { animation: ha-up .85s cubic-bezier(.22,.61,.36,1) both; }
    .ha0 { animation-delay: .08s; } .ha1 { animation-delay: .2s; } .ha2 { animation-delay: .34s; }
    .ha3 { animation-delay: .48s; } .ha4 { animation-delay: .62s; } .ha5 { animation-delay: .76s; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .ql-hero { grid-template-columns: 1fr; }
      .ql-hero-right { display: none; }
      .ql-naming-grid { grid-template-columns: 1fr 1fr; }
      .ql-iter-strip { grid-template-columns: repeat(3,1fr); }
      .ql-ux-cols { grid-template-columns: 1fr; }
      .ql-results-row { grid-template-columns: 1fr 1fr; }
      .ql-deliv-grid { grid-template-columns: 1fr 1fr; }
      .ql-sec-header { grid-template-columns: 1fr; gap: 12px; }
    }
    @media (max-width: 640px) {
      .ql-naming-grid, .ql-logo-row, .ql-results-row, .ql-deliv-grid { grid-template-columns: 1fr; }
      .ql-iter-strip { grid-template-columns: repeat(2,1fr); }
      .ql-container { padding: 0 20px; }
      .ql-hero-left { padding: 60px 24px; }
      .ql-back { left: 24px; }
    }
  </style>

  <div class="ql-wrap">

    <!-- ══ HERO ══ -->
    <section class="ql-hero">
      <div class="ql-hero-bg">
        <img src="/images/qljoy-hero.png" alt="QL&Joy Studio" fetchpriority="high" decoding="async" />
      </div>
      <div class="ql-hero-left">
        <div class="ql-hero-num">001</div>
        <a href="/#cases" class="ql-back">
