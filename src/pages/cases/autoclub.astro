  <script>
    const io = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('v'); io.unobserve(e.target); } }),
      { threshold: .08, rootMargin: '0px 0px -40px 0px' }
    );
    function initReveal() { document.querySelectorAll('.r:not(.v)').forEach(el => io.observe(el)); }
    initReveal();
    document.addEventListener('astro:after-swap', initReveal);
  </script>

  <script>
    // ── Booking Module ──────────────────────────────────────────
    const BOOKED  = ['2026-03-24','2026-03-25','2026-03-26','2026-04-05','2026-04-06','2026-04-07','2026-04-08','2026-04-15','2026-04-16','2026-04-22','2026-04-23','2026-04-24','2026-04-25','2026-04-26','2026-04-27'];
    const PARTIAL = ['2026-03-28','2026-04-12'];
    const PRICE_PER_DAY = 2400;
    const MONTHS = ['Styczeń','Luty','Marzec','Kwiecień','Maj','Czerwiec','Lipiec','Sierpień','Wrzesień','Październik','Listopad','Grudzień'];
    const DAYS_PL = ['Pn','Wt','Śr','Cz','Pt','Sb','Nd'];

    let calYear: number, calMonth: number;
    let selStart: string|null = null, selEnd: string|null = null;

    function initBooking() {
      const grid = document.getElementById('calGrid');
      if (!grid) return;

      const now = new Date();
      calYear  = now.getFullYear();
      calMonth = now.getMonth();

      document.getElementById('calPrev')!.onclick = () => { calMonth--; if (calMonth < 0) { calMonth = 11; calYear--; } renderCal(); };
      document.getElementById('calNext')!.onclick = () => { calMonth++; if (calMonth > 11) { calMonth = 0; calYear++; } renderCal(); };
      document.getElementById('pickup-date')!.addEventListener('change', calcPrice);
      document.getElementById('return-date')!.addEventListener('change', calcPrice);
      document.getElementById('insurance')!.addEventListener('change', calcPrice);
      document.getElementById('bookingSubmit')!.addEventListener('click', submitBooking);

      renderCal();
    }

    function renderCal() {
      const label = document.getElementById('calMonthLabel');
      const grid  = document.getElementById('calGrid');
      if (!label || !grid) return;

      label.textContent = `${MONTHS[calMonth]} ${calYear}`;
      grid.innerHTML = '';

      DAYS_PL.forEach(d => {
        const el = document.createElement('div');
        el.className = 'cal-day-name';
        el.textContent = d;
        grid.appendChild(el);
      });

      const firstDay = new Date(calYear, calMonth, 1).getDay();
      const offset   = (firstDay + 6) % 7;
      for (let i = 0; i < offset; i++) {
        const el = document.createElement('div');
        el.className = 'cal-day empty';
        grid.appendChild(el);
      }

      const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
      const today = new Date(); today.setHours(0,0,0,0);

      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        const date    = new Date(calYear, calMonth, d);
        const el      = document.createElement('div');
        el.className  = 'cal-day';
        el.textContent = String(d);

        if (date < today)                   el.classList.add('past');
        else if (BOOKED.includes(dateStr))  el.classList.add('booked');
        else if (PARTIAL.includes(dateStr)) el.classList.add('partial');
        else                                el.classList.add('available');

        if (dateStr === today.toISOString().split('T')[0]) el.classList.add('today');
        if (selStart && dateStr === selStart) el.classList.add('selected-start');
        if (selEnd   && dateStr === selEnd)   el.classList.add('selected-end');
        if (selStart && selEnd && dateStr > selStart && dateStr < selEnd) el.classList.add('in-range');

        if (!el.classList.contains('booked') && !el.classList.contains('past')) {
          el.onclick = () => onDayClick(dateStr);
        }
        grid.appendChild(el);
      }
    }

    function onDayClick(dateStr: string) {
      const pickup = document.getElementById('pickup-date') as HTMLInputElement;
      const ret    = document.getElementById('return-date') as HTMLInputElement;

      if (!selStart || (selStart && selEnd)) {
        selStart = dateStr; selEnd = null;
        pickup.value = dateStr; ret.value = '';
      } else {
        if (dateStr <= selStart) { selStart = dateStr; pickup.value = dateStr; }
        else { selEnd = dateStr; ret.value = dateStr; }
      }
      renderCal();
      calcPrice();
    }

    function calcPrice() {
      const p   = (document.getElementById('pickup-date') as HTMLInputElement).value;
      const r   = (document.getElementById('return-date') as HTMLInputElement).value;
      const ins = parseInt((document.getElementById('insurance') as HTMLSelectElement).value) || 0;
      const summary = document.getElementById('priceSummary')!;

      if (!p || !r || r <= p) { summary.style.display = 'none'; return; }
      const days = Math.round((new Date(r).getTime() - new Date(p).getTime()) / 86400000);
      if (days < 1) { summary.style.display = 'none'; return; }

      const fmt = (n: number) => n.toLocaleString('pl-PL') + ' zł';
      const base = days * PRICE_PER_DAY;
      const insTotal = ins * days;

      document.getElementById('ps-days')!.textContent = String(days);
      document.getElementById('ps-base')!.textContent = fmt(base);

      const insRow = document.getElementById('ps-ins-row')!;
      if (ins > 0) {
        insRow.style.display = '';
        document.getElementById('ps-ins-label')!.textContent = ins === 150 ? 'Ubezpieczenie Comfort' : 'Ubezpieczenie Premium';
        document.getElementById('ps-ins')!.textContent = fmt(insTotal);
      } else {
        insRow.style.display = 'none';
      }

      (document.querySelector('#priceSummary .price-total-num') as HTMLElement).textContent = fmt(base + insTotal + 10000);
      summary.style.display = '';
    }

    function submitBooking() {
      const name  = (document.getElementById('client-name')  as HTMLInputElement).value.trim();
      const phone = (document.getElementById('client-phone') as HTMLInputElement).value.trim();
      const email = (document.getElementById('client-email') as HTMLInputElement).value.trim();
      const p     = (document.getElementById('pickup-date')  as HTMLInputElement).value;
      const r     = (document.getElementById('return-date')  as HTMLInputElement).value;
      const toast = document.getElementById('bookingToast')!;
      const btn   = document.getElementById('bookingSubmit') as HTMLButtonElement;

      if (!name || !phone || !email || !p || !r) {
        toast.style.color = '#EF4444'; toast.textContent = 'Uzupełnij wszystkie wymagane pola.'; return;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        toast.style.color = '#EF4444'; toast.textContent = 'Podaj prawidłowy adres e-mail.'; return;
      }

      btn.textContent = 'Wysyłanie…'; btn.disabled = true;
      setTimeout(() => {
        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Wysłano!`;
        btn.style.background = 'linear-gradient(135deg,#059669,#10B981)';
        btn.style.boxShadow  = '0 6px 24px rgba(16,185,129,0.40)';
        toast.style.color = '#059669';
        toast.textContent = `✓ Zapytanie wysłane! Oddzwonimy wkrótce, ${name.split(' ')[0]}.`;
      }, 1400);
    }

    // Billing toggle
    const PRICES = { monthly: { basic: 99, premium: 199, vip: 399 }, annual: { basic: 79, premium: 159, vip: 319 } };
    let currentBilling = 'monthly';

    function initBillingToggle() {
      const btnM = document.getElementById('toggleMonthly');
      const btnA = document.getElementById('toggleAnnual');
      if (!btnM || !btnA) return;
      btnM.onclick = () => setBilling('monthly');
      btnA.onclick = () => setBilling('annual');
    }

    function setBilling(mode: string) {
      if (mode === currentBilling) return;
      currentBilling = mode;
      const btnM = document.getElementById('toggleMonthly')!;
      const btnA = document.getElementById('toggleAnnual')!;
      btnM.classList.toggle('active', mode === 'monthly');
      btnA.classList.toggle('active', mode === 'annual');

      (['basic','premium','vip'] as const).forEach(plan => {
        const priceEl = document.getElementById(`price-${plan}`);
        const savingEl = document.getElementById(`saving-${plan}`);
        const oldEl = document.getElementById(`old-${plan}`);
        const promoEl = document.getElementById(`promo-${plan}`);
        if (!priceEl) return;

        priceEl.classList.add('switching');
        setTimeout(() => {
          priceEl.textContent = String((PRICES as any)[mode][plan]);
          if (mode === 'annual') {
            if (savingEl) savingEl.style.visibility = 'visible';
            if (oldEl) { oldEl.style.visibility = 'visible'; oldEl.textContent = `było ${(PRICES as any).monthly[plan]} zł/mies.`; }
            if (promoEl) promoEl.style.display = 'inline-flex';
          } else {
            if (savingEl) savingEl.style.visibility = 'hidden';
            if (oldEl) oldEl.style.visibility = 'hidden';
            if (promoEl) promoEl.style.display = 'none';
          }
          priceEl.classList.remove('switching');
        }, 220);
      });
    }

    function init() {
      initBooking();
      initBillingToggle();
      selStart = null; selEnd = null;
    }

    init();
    document.addEventListener('astro:after-swap', init);
  </script>
</BaseLayout>
