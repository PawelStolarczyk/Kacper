---
// HeroBg.astro
// Użycie: <HeroBg /> w sekcji hero
// Komponent zajmuje 100% rodzica — ustaw position: relative na rodzicu
---

<canvas id="hero-bg-canvas"></canvas>

<style>
  #hero-bg-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  (function () {
    const canvas = document.getElementById("hero-bg-canvas") as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext("2d")!;

    let W = 0,
      H = 0,
      t = 0;

    const COLS = 30;
    const ROWS = 18;

    // ── Palety kolorów ─────────────────────────────────────────────
    type RGB = [number, number, number];
    interface Palette {
      grid: RGB;
      blob1: RGB;
      blob2: RGB;
      blob3: RGB;
    }

    const palettes: Palette[] = [
      { grid: [0, 229, 255],   blob1: [0, 229, 255],   blob2: [80, 0, 200],    blob3: [0, 100, 180]  },
      { grid: [179, 136, 255], blob1: [120, 0, 255],   blob2: [0, 229, 255],   blob3: [255, 80, 180] },
      { grid: [255, 179, 0],   blob1: [255, 100, 0],   blob2: [179, 136, 255], blob3: [0, 200, 150]  },
      { grid: [0, 229, 255],   blob1: [0, 180, 255],   blob2: [255, 50, 120],  blob3: [100, 0, 255]  },
    ];

    let palIdx = 0,
      palNext = 1,
      palT = 0;
    const PAL_DUR = 400;

    function lerpC(a: RGB, b: RGB, f: number): RGB {
      return [
        Math.round(a[0] + (b[0] - a[0]) * f),
        Math.round(a[1] + (b[1] - a[1]) * f),
        Math.round(a[2] + (b[2] - a[2]) * f),
      ];
    }

    function getPal(): Palette {
      const f = Math.min(palT / 80, 1);
      const c = palettes[palIdx];
      const n = palettes[palNext];
      return {
        grid:  lerpC(c.grid,  n.grid,  f),
        blob1: lerpC(c.blob1, n.blob1, f),
        blob2: lerpC(c.blob2, n.blob2, f),
        blob3: lerpC(c.blob3, n.blob3, f),
      };
    }

    // ── Typy cząsteczek ────────────────────────────────────────────
    type ParticleType = "cross" | "ring" | "dash" | "diamond";
    type PalKey = "blob1" | "blob2" | "blob3";

    interface Particle {
      type: ParticleType;
      x: number;
      y: number;
      vx: number;
      vy: number;
      alpha: number;
      palKey: PalKey;
      // cross / dash
      angle?: number;
      spin?: number;
      size?: number;
      len?: number;
      // ring
      r?: number;
      pulsePhase?: number;
      // diamond
      wobble?: number;
      wobbleSpd?: number;
    }

    const KEYS: PalKey[] = ["blob1", "blob2", "blob3"];
    const rk = () => KEYS[Math.floor(Math.random() * 3)];

    function mkCross(): Particle {
      return {
        type: "cross",
        x: Math.random() * W, y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.18,
        angle: Math.random() * Math.PI,
        spin: (Math.random() - 0.5) * 0.025,
        size: 4 + Math.random() * 6,
        alpha: 0.25 + Math.random() * 0.45,
        palKey: rk(),
      };
    }

    function mkRing(): Particle {
      return {
        type: "ring",
        x: Math.random() * W, y: -20,
        vx: (Math.random() - 0.5) * 0.3,
        vy: 0.4 + Math.random() * 0.7,
        r: 5 + Math.random() * 10,
        pulsePhase: Math.random() * Math.PI * 2,
        alpha: 0.2 + Math.random() * 0.35,
        palKey: rk(),
      };
    }

    function mkDash(): Particle {
      const angle = -Math.PI / 4 + (Math.random() - 0.5) * 0.8;
      const spd = 0.6 + Math.random() * 1.1;
      return {
        type: "dash",
        x: Math.random() * W, y: Math.random() * H,
        vx: Math.cos(angle) * spd,
        vy: Math.sin(angle) * spd,
        angle,
        spin: (Math.random() - 0.5) * 0.04,
        len: 8 + Math.random() * 18,
        alpha: 0.2 + Math.random() * 0.4,
        palKey: rk(),
      };
    }

    function mkDiamond(): Particle {
      return {
        type: "diamond",
        x: Math.random() * W, y: H + 20,
        vx: Math.sin(Math.random() * Math.PI * 2) * 0.2,
        vy: -(0.25 + Math.random() * 0.5),
        wobble: Math.random() * Math.PI * 2,
        wobbleSpd: 0.02 + Math.random() * 0.015,
        size: 4 + Math.random() * 7,
        alpha: 0.18 + Math.random() * 0.38,
        palKey: rk(),
      };
    }

    let particles: Particle[] = [];

    function initParticles() {
      particles = [];
      for (let i = 0; i < 18; i++) particles.push(mkCross());
      for (let i = 0; i < 16; i++) particles.push(mkRing());
      for (let i = 0; i < 14; i++) particles.push(mkDash());
      for (let i = 0; i < 12; i++) particles.push(mkDiamond());
    }

    // ── Draw helpers ───────────────────────────────────────────────
    function rgba(col: RGB, a: number) {
      return `rgba(${col[0]},${col[1]},${col[2]},${a})`;
    }

    function drawCross(p: Particle, col: RGB) {
      const s = p.size!;
      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.angle!);
      ctx.strokeStyle = rgba(col, p.alpha);
      ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(-s, 0); ctx.lineTo(s, 0); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(0, -s); ctx.lineTo(0, s); ctx.stroke();
      ctx.restore();
      p.angle! && (p.angle = p.angle! + p.spin!);
      p.x += p.vx; p.y += p.vy;
      if (p.x < -20 || p.x > W + 20 || p.y < -20 || p.y > H + 20) {
        Object.assign(p, mkCross());
        p.x = Math.random() * W;
        p.y = Math.random() * H;
      }
    }

    function drawRing(p: Particle, col: RGB) {
      const pulse = p.r! + 2 * Math.sin(t * 1.8 + p.pulsePhase!);
      ctx.save();
      ctx.beginPath();
      ctx.arc(p.x, p.y, Math.max(pulse, 1), 0, Math.PI * 2);
      ctx.strokeStyle = rgba(col, p.alpha);
      ctx.lineWidth = 0.8;
      ctx.stroke();
      ctx.restore();
      p.x += p.vx + Math.sin(t * 0.5 + p.pulsePhase!) * 0.4;
      p.y += p.vy;
      if (p.y > H + 30) Object.assign(p, mkRing());
    }

    function drawDash(p: Particle, col: RGB) {
      const half = p.len! / 2;
      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.angle!);
      ctx.strokeStyle = rgba(col, p.alpha);
      ctx.lineWidth = 1.2;
      ctx.lineCap = "round";
      ctx.beginPath(); ctx.moveTo(-half, 0); ctx.lineTo(half, 0); ctx.stroke();
      ctx.restore();
      p.angle = p.angle! + p.spin!;
      p.x += p.vx; p.y += p.vy;
      if (p.x < -40 || p.x > W + 40 || p.y < -40 || p.y > H + 40) {
        Object.assign(p, mkDash());
        p.x = Math.random() * W;
        p.y = Math.random() * H;
      }
    }

    function drawDiamond(p: Particle, col: RGB) {
      const s = p.size!;
      const wx = Math.sin(t * p.wobbleSpd! + p.wobble!) * 3;
      ctx.save();
      ctx.translate(p.x + wx, p.y);
      ctx.strokeStyle = rgba(col, p.alpha);
      ctx.fillStyle   = rgba(col, p.alpha * 0.18);
      ctx.lineWidth = 0.8;
      ctx.beginPath();
      ctx.moveTo(0, -s); ctx.lineTo(s * 0.6, 0);
      ctx.lineTo(0, s);  ctx.lineTo(-s * 0.6, 0);
      ctx.closePath();
      ctx.fill(); ctx.stroke();
      ctx.restore();
      p.x += p.vx; p.y += p.vy;
      if (p.y < -30) Object.assign(p, mkDiamond());
    }

    // ── Blobs ──────────────────────────────────────────────────────
    function drawBlobs(pal: Palette) {
      const blobs = [
        { x: W * 0.75, y: H * 0.3,  r: W * 0.38, col: pal.blob1, a: 0.09 + 0.04 * Math.sin(t * 0.4)    },
        { x: W * 0.15, y: H * 0.7,  r: W * 0.28, col: pal.blob2, a: 0.07 + 0.03 * Math.sin(t * 0.3 + 1) },
        { x: W * 0.55, y: H * 0.85, r: W * 0.22, col: pal.blob3, a: 0.06 + 0.03 * Math.cos(t * 0.25)   },
      ];
      blobs.forEach(({ x, y, r, col, a }) => {
        const g = ctx.createRadialGradient(x, y, 0, x, y, r);
        g.addColorStop(0,   rgba(col, a));
        g.addColorStop(0.5, rgba(col, a * 0.4));
        g.addColorStop(1,   rgba(col, 0));
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, W, H);
      });
    }

    // ── Grid ───────────────────────────────────────────────────────
    function drawGrid(pal: Palette) {
      const cW = W / COLS;
      const cH = H / ROWS;
      const [r, g, b] = pal.grid;

      for (let c = 0; c <= COLS; c++) {
        ctx.beginPath();
        for (let row = 0; row <= ROWS; row++) {
          const wave = Math.sin(t * 0.55 + c * 0.28 + row * 0.1) * 2.8;
          const y = row * cH + wave;
          row === 0 ? ctx.moveTo(c * cW, y) : ctx.lineTo(c * cW, y);
        }
        const dist = Math.abs(c - COLS / 2) / (COLS / 2);
        const a = (0.07 - dist * 0.055) * (0.6 + 0.4 * Math.sin(t * 0.3 + c * 0.2));
        ctx.strokeStyle = `rgba(${r},${g},${b},${Math.max(a, 0)})`;
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }

      for (let row = 0; row <= ROWS; row++) {
        ctx.beginPath();
        for (let c = 0; c <= COLS; c++) {
          const wave = Math.sin(t * 0.45 + row * 0.35 + c * 0.08) * 2.2;
          c === 0 ? ctx.moveTo(c * cW + wave, row * cH) : ctx.lineTo(c * cW + wave, row * cH);
        }
        const dist = Math.abs(row - ROWS / 2) / (ROWS / 2);
        const a = (0.055 - dist * 0.04) * (0.5 + 0.5 * Math.sin(t * 0.25 + row * 0.3));
        ctx.strokeStyle = `rgba(${r},${g},${b},${Math.max(a, 0)})`;
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }
    }

    // ── Accent beam ────────────────────────────────────────────────
    function drawBeam(pal: Palette) {
      const bx = W * 0.7;
      const [r, g, b] = pal.grid;
      const a = 0.04 + 0.025 * Math.sin(t * 0.6);
      const gr = ctx.createLinearGradient(bx, 0, bx, H);
      gr.addColorStop(0,    `rgba(${r},${g},${b},0)`);
      gr.addColorStop(0.35, `rgba(${r},${g},${b},${a})`);
      gr.addColorStop(0.65, `rgba(${r},${g},${b},${a})`);
      gr.addColorStop(1,    `rgba(${r},${g},${b},0)`);
      ctx.fillStyle = gr;
      ctx.fillRect(bx - 1, 0, 2, H);
    }

    // ── Resize ─────────────────────────────────────────────────────
    function resize() {
      const rect = canvas.parentElement!.getBoundingClientRect();
      W = canvas.width  = rect.width;
      H = canvas.height = rect.height;
    }

    // ── Loop ───────────────────────────────────────────────────────
    let rafId: number;

    function loop() {
      t += 0.013;
      palT++;
      if (palT >= PAL_DUR) {
        palIdx = palNext;
        palNext = (palNext + 1) % palettes.length;
        palT = 0;
      }

      ctx.clearRect(0, 0, W, H);
      const pal = getPal();
      drawBlobs(pal);
      drawGrid(pal);
      drawBeam(pal);
      particles.forEach((p) => {
        const col = pal[p.palKey];
        if      (p.type === "cross")   drawCross(p, col);
        else if (p.type === "ring")    drawRing(p, col);
        else if (p.type === "dash")    drawDash(p, col);
        else if (p.type === "diamond") drawDiamond(p, col);
      });

      rafId = requestAnimationFrame(loop);
    }

    // ── Init ───────────────────────────────────────────────────────
    resize();
    initParticles();
    loop();

    const ro = new ResizeObserver(() => resize());
    ro.observe(canvas.parentElement!);

    // Cleanup przy Astro View Transitions
    document.addEventListener("astro:before-swap", () => {
      cancelAnimationFrame(rafId);
      ro.disconnect();
    });
  })();
</script>
