---
// src/components/sections/Hero.astro
import Button from '@components/ui/Button.astro';
import HeroBg from '@components/sections/HeroBg.astro';
---

<section id="hero">
  <HeroBg />

  <!-- Treść -->
  <div class="hero-inner">

    <div class="ha ha0 hero-badge">
      <span class="badge-dot"></span>
      Dostępny do współpracy · 2025
    </div>

    <div class="ha ha1 hero-title">Kacper Stolarczyk</div>
    <div class="ha ha2 hero-title hero-sub-title">UI/UX Designer</div>

    <div class="ha ha3 hero-label">
      <span class="label-line"></span>
      AI-Augmented Design
    </div>

    <p class="ha ha4 hero-desc">
      Projektuję interfejsy, które <strong>rozumieją ludzi</strong>.
      Łączę klasyczny warsztat UX z <strong>narzędziami AI</strong>
      — skracam czas dostarczania o 60%, nie rezygnując z głębi procesu.
    </p>

    <div class="ha ha5 hero-buttons">
      <Button href="/#portfolio" variant="primary">Zobacz portfolio</Button>
      <Button href="/#about"     variant="ghost">O mnie</Button>
    </div>

    <!-- Stats -->
    <div class="ha ha5 hero-stats">
      {[
        { n: '24', suffix: '+',   label: 'Projektów'     },
        { n: '6',  suffix: 'lat', label: 'Doświadczenia' },
        { n: '60', suffix: '%',   label: 'Szybciej z AI' },
      ].map(({ n, suffix, label }, i) => (
        <div class:list={['stat-box', i < 2 && 'stat-box--no-right']}>
          <div class="stat-n">
            <span class="count-num" data-target={n}>0</span>
            <span class="stat-suffix">{suffix}</span>
          </div>
          <div class="stat-l">{label}</div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  section {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    padding-top: 60px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding: 80px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 720px;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    margin-bottom: 36px;
    font-size: 10px; letter-spacing: .22em; text-transform: uppercase;
    color: var(--accent);
  }
  .badge-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent);
    animation: blink 1.8s ease-in-out infinite;
  }

  /* Titles */
  .hero-title {
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(44px, 5.2vw, 80px);
    line-height: 1; letter-spacing: -.04em;
  }
  .hero-sub-title {
    color: var(--fg-30);
    margin-bottom: 36px;
  }

  /* Label */
  .hero-label {
    font-size: 13px; letter-spacing: .12em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 28px;
    display: flex; align-items: center; gap: 12px;
  }
  .label-line {
    width: 40px; height: 1px;
    background: var(--accent); display: inline-block;
  }

  /* Desc */
  .hero-desc {
    font-size: 15px; line-height: 1.85;
    color: var(--fg-60); max-width: 440px; margin-bottom: 52px;
  }
  .hero-desc strong { color: var(--fg); font-weight: 500; }

  /* Buttons */
  .hero-buttons { display: flex; gap: 14px; margin-bottom: 72px; }

  /* Stats */
  .hero-stats { display: flex; }
  .stat-box {
    padding: 24px 32px;
    border: 1px solid var(--border);
  }
  .stat-box--no-right { border-right: none; }
  .stat-n {
    font-family: var(--font-display); font-weight: 800;
    font-size: 30px; line-height: 1; margin-bottom: 4px;
  }
  .stat-suffix { color: var(--accent); }
  .stat-l {
    font-size: 9px; letter-spacing: .18em;
    text-transform: uppercase; color: var(--fg-30);
  }

  /* Animations */
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
  @keyframes up { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:none} }
  .ha { animation: up .9s cubic-bezier(.22,.61,.36,1) both; }
  .ha0{animation-delay:.10s} .ha1{animation-delay:.24s} .ha2{animation-delay:.38s}
  .ha3{animation-delay:.52s} .ha4{animation-delay:.66s} .ha5{animation-delay:.80s}

  /* Responsive */
  @media(max-width:900px) {
    .hero-inner { padding: 60px 32px; }
  }
  @media(max-width:600px) {
    .hero-inner { padding: 48px 20px 56px; }
    .hero-title { font-size: clamp(28px, 9vw, 42px) !important; }
    .hero-desc { max-width: 100%; }
    .hero-buttons { flex-direction: column; }
    .hero-buttons a { text-align: center; width: 100%; justify-content: center; }
    .stat-box { padding: 14px 16px; flex: 1 1 calc(33% - 1px); min-width: 0; }
  }
</style>

<script>
  function animateCounter(el: Element, target: number) {
    const dur = 1400, t0 = performance.now();
    (function tick(now: number) {
      const p = Math.min((now - t0) / dur, 1);
      const e = 1 - Math.pow(1 - p, 3);
      el.textContent = String(Math.round(e * target));
      if (p < 1) requestAnimationFrame(tick);
    })(t0);
  }
  const cObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.count-num').forEach(el => {
          animateCounter(el, parseInt((el as HTMLElement).dataset.target ?? '0'));
        });
        cObs.unobserve(e.target);
      }
    });
  }, { threshold: .5 });
  document.querySelectorAll('[data-target]').forEach(el =>
    cObs.observe(el.closest('div')!)
  );
</script>
