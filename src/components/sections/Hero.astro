---
// src/components/sections/Hero.astro
import Button from '@components/ui/Button.astro';
---

<section
  id="hero"
  style="
    position:relative; z-index:1; min-height:100vh;
    display:grid; grid-template-columns:1fr 1fr;
    padding-top:60px; overflow:hidden;
  "
>
  <!-- LEFT: text content -->
  <div style="padding:80px 64px; display:flex; flex-direction:column; justify-content:center">

    <div
      class="ha ha0"
      style="display:inline-flex; align-items:center; gap:8px; margin-bottom:36px;
             font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:var(--accent)"
    >
      <span style="width:7px; height:7px; border-radius:50%; background:var(--accent); animation:blink 1.8s ease-in-out infinite"></span>
      Dostępny do współpracy · 2025
    </div>

    <div class="ha ha1 hero-title" style="font-family:var(--font-display); font-weight:800; font-size:clamp(44px,5.2vw,80px); line-height:1; letter-spacing:-.04em">
      Kacper Stolarczyk
    </div>
    <div class="ha ha2 hero-title" style="font-family:var(--font-display); font-weight:300; font-size:clamp(44px,5.2vw,80px); line-height:1; letter-spacing:-.04em; color:var(--fg-30); margin-bottom:36px">
      UI/UX Designer
    </div>

    <div class="ha ha3" style="font-size:13px; letter-spacing:.12em; text-transform:uppercase; color:var(--accent); margin-bottom:28px; display:flex; align-items:center; gap:12px">
      <span style="width:40px; height:1px; background:var(--accent); display:inline-block"></span>
      AI-Augmented Design
    </div>

    <p class="ha ha4" style="font-size:15px; line-height:1.85; color:var(--fg-60); max-width:440px; margin-bottom:52px">
      Projektuję interfejsy, które <strong style="color:var(--fg); font-weight:500">rozumieją ludzi</strong>.
      Łączę klasyczny warsztat UX z <strong style="color:var(--fg); font-weight:500">narzędziami AI</strong>
      — skracam czas dostarczania o 60%, nie rezygnując z głębi procesu.
    </p>

    <div class="ha ha5 hero-buttons" style="display:flex; gap:14px; margin-bottom:72px">
      <Button href="/#portfolio" variant="primary">Zobacz portfolio</Button>
      <Button href="/#about"     variant="ghost">O mnie</Button>
    </div>

    <!-- Stats -->
    <div class="ha ha5" style="display:flex">
      {[
        { n: '24', suffix: '+',   label: 'Projektów'       },
        { n: '6',  suffix: 'lat', label: 'Doświadczenia'   },
        { n: '60', suffix: '%',   label: 'Szybciej z AI'   },
      ].map(({ n, suffix, label }, i) => (
        <div style={`padding:24px 32px; border:1px solid var(--border); border-right:${i < 2 ? 'none' : '1px solid var(--border)'}`}>
          <div style="font-family:var(--font-display); font-weight:800; font-size:30px; line-height:1; margin-bottom:4px">
            <span class="count-num" data-target={n}>0</span>
            <span style="color:var(--accent)">{suffix}</span>
          </div>
          <div style="font-size:9px; letter-spacing:.18em; text-transform:uppercase; color:var(--fg-30)">{label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- RIGHT: animated AI diagram -->
  <div
    style="position:relative; display:flex; align-items:center; justify-content:center; padding:80px 48px; overflow:hidden"
  >
    <div style="position:absolute; inset:0; background:radial-gradient(ellipse 60% 60% at 60% 40%, rgba(0,229,160,.06) 0%, transparent 70%)"></div>
    <div style="width:100%; max-width:500px; position:relative; z-index:2">
      <!-- SVG AI diagram (inlined from portfolio HTML) -->
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" width="100%">
        <defs>
          <radialGradient id="cg" cx="50%" cy="50%" r="50%">
            <stop offset="0%"   stop-color="#00E5A0" stop-opacity=".9"/>
            <stop offset="100%" stop-color="#00E5A0" stop-opacity="0"/>
          </radialGradient>
          <filter id="glow"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          <filter id="glow2"><feGaussianBlur stdDeviation="6" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        </defs>
        <g opacity=".06"><line x1="0" y1="100" x2="500" y2="100" stroke="#00E5A0" stroke-width=".5"/><line x1="0" y1="200" x2="500" y2="200" stroke="#00E5A0" stroke-width=".5"/><line x1="0" y1="300" x2="500" y2="300" stroke="#00E5A0" stroke-width=".5"/><line x1="0" y1="400" x2="500" y2="400" stroke="#00E5A0" stroke-width=".5"/><line x1="100" y1="0" x2="100" y2="500" stroke="#00E5A0" stroke-width=".5"/><line x1="200" y1="0" x2="200" y2="500" stroke="#00E5A0" stroke-width=".5"/><line x1="300" y1="0" x2="300" y2="500" stroke="#00E5A0" stroke-width=".5"/><line x1="400" y1="0" x2="400" y2="500" stroke="#00E5A0" stroke-width=".5"/></g>
        <g class="orbit-ring"><circle cx="250" cy="250" r="180" fill="none" stroke="#00E5A0" stroke-width=".5" stroke-dasharray="4 12" opacity=".25"/><circle cx="250" cy="70" r="5" fill="#00E5A0" opacity=".8" filter="url(#glow)"/><circle cx="430" cy="250" r="4" fill="#00E5A0" opacity=".6" filter="url(#glow)"/></g>
        <g class="orbit-ring2"><circle cx="250" cy="250" r="130" fill="none" stroke="#00E5A0" stroke-width=".7" stroke-dasharray="2 8" opacity=".3"/><circle cx="250" cy="120" r="4.5" fill="#00E5A0" opacity=".7" filter="url(#glow)"/><circle cx="380" cy="250" r="3.5" fill="#00E5A0" opacity=".5"/><circle cx="250" cy="380" r="4" fill="#00E5A0" opacity=".6" filter="url(#glow)"/></g>
        <g class="orbit-ring3"><circle cx="250" cy="250" r="80" fill="none" stroke="#00E5A0" stroke-width="1" stroke-dasharray="3 6" opacity=".35"/><circle cx="250" cy="170" r="5" fill="#00E5A0" opacity=".9" filter="url(#glow)"/><circle cx="330" cy="250" r="4" fill="#00E5A0" opacity=".7"/></g>
        <g opacity=".4">
          <line x1="250" y1="250" x2="100" y2="140" stroke="#00E5A0" stroke-width=".8" stroke-dasharray="4 4"><animate attributeName="stroke-dashoffset" from="32" to="0" dur="2s" repeatCount="indefinite"/></line>
          <line x1="250" y1="250" x2="400" y2="130" stroke="#00E5A0" stroke-width=".8" stroke-dasharray="4 4"><animate attributeName="stroke-dashoffset" from="0" to="32" dur="2.5s" repeatCount="indefinite"/></line>
          <line x1="250" y1="250" x2="130" y2="380" stroke="#00E5A0" stroke-width=".8" stroke-dasharray="4 4"><animate attributeName="stroke-dashoffset" from="32" to="0" dur="3s" repeatCount="indefinite"/></line>
          <line x1="250" y1="250" x2="390" y2="360" stroke="#00E5A0" stroke-width=".8" stroke-dasharray="4 4"><animate attributeName="stroke-dashoffset" from="0" to="32" dur="1.8s" repeatCount="indefinite"/></line>
        </g>
        <g filter="url(#glow)"><rect x="60" y="110" width="82" height="48" fill="rgba(0,229,160,.06)" stroke="#00E5A0" stroke-width=".8" rx="2"/><text x="101" y="130" font-family="Plus Jakarta Sans,sans-serif" font-weight="700" font-size="8.5" fill="#00E5A0" text-anchor="middle" letter-spacing=".5">UX RESEARCH</text><text x="101" y="146" font-family="DM Sans,sans-serif" font-size="7.5" fill="rgba(0,229,160,.5)" text-anchor="middle">AI-assisted</text></g>
        <g filter="url(#glow)"><rect x="355" y="100" width="90" height="48" fill="rgba(0,229,160,.06)" stroke="#00E5A0" stroke-width=".8" rx="2"/><text x="400" y="120" font-family="Plus Jakarta Sans,sans-serif" font-weight="700" font-size="8.5" fill="#00E5A0" text-anchor="middle" letter-spacing=".5">BRAND ID</text><text x="400" y="136" font-family="DM Sans,sans-serif" font-size="7.5" fill="rgba(0,229,160,.5)" text-anchor="middle">Generative</text></g>
        <g filter="url(#glow)"><rect x="72" y="355" width="90" height="48" fill="rgba(0,229,160,.06)" stroke="#00E5A0" stroke-width=".8" rx="2"/><text x="117" y="375" font-family="Plus Jakarta Sans,sans-serif" font-weight="700" font-size="8.5" fill="#00E5A0" text-anchor="middle" letter-spacing=".5">PROTOTYPE</text><text x="117" y="391" font-family="DM Sans,sans-serif" font-size="7.5" fill="rgba(0,229,160,.5)" text-anchor="middle">Rapid iteration</text></g>
        <g filter="url(#glow)"><rect x="347" y="346" width="100" height="48" fill="rgba(0,229,160,.06)" stroke="#00E5A0" stroke-width=".8" rx="2"/><text x="397" y="366" font-family="Plus Jakarta Sans,sans-serif" font-weight="700" font-size="8.5" fill="#00E5A0" text-anchor="middle" letter-spacing=".5">E-COMMERCE</text><text x="397" y="382" font-family="DM Sans,sans-serif" font-size="7.5" fill="rgba(0,229,160,.5)" text-anchor="middle">UX-optimized</text></g>
        <circle cx="250" cy="250" r="50" fill="url(#cg)" opacity=".25"><animate attributeName="r" values="45;55;45" dur="3s" repeatCount="indefinite"/><animate attributeName="opacity" values=".2;.35;.2" dur="3s" repeatCount="indefinite"/></circle>
        <circle cx="250" cy="250" r="28" fill="rgba(0,229,160,.1)" stroke="#00E5A0" stroke-width="1" filter="url(#glow2)"/>
        <circle cx="250" cy="250" r="14" fill="rgba(0,229,160,.3)" stroke="#00E5A0" stroke-width="1.5"/>
        <text x="250" y="246" font-family="Plus Jakarta Sans,sans-serif" font-weight="800" font-size="8" fill="#00E5A0" text-anchor="middle" letter-spacing=".5">AI</text>
        <text x="250" y="258" font-family="Plus Jakarta Sans,sans-serif" font-weight="800" font-size="8" fill="#00E5A0" text-anchor="middle" letter-spacing=".5">CORE</text>
        <text x="250" y="488" font-family="Plus Jakarta Sans,sans-serif" font-weight="300" font-size="9" fill="rgba(0,229,160,.35)" text-anchor="middle" letter-spacing="2">AI-AUGMENTED DESIGN PROCESS</text>
      </svg>
    </div>
  </div>
</section>

<style>
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
  @keyframes up { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:none} }
  .ha { animation: up .9s cubic-bezier(.22,.61,.36,1) both; }
  .ha0{animation-delay:.10s} .ha1{animation-delay:.24s} .ha2{animation-delay:.38s}
  .ha3{animation-delay:.52s} .ha4{animation-delay:.66s} .ha5{animation-delay:.80s}

  .orbit-ring  { animation:spin 18s linear infinite; transform-origin:center; transform-box:fill-box; }
  .orbit-ring2 { animation:spin 28s linear infinite reverse; transform-origin:center; transform-box:fill-box; }
  .orbit-ring3 { animation:spin 12s linear infinite; transform-origin:center; transform-box:fill-box; }
  @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

  @media(max-width:1100px) {
    section { grid-template-columns:1fr !important; min-height:auto !important; }
    section > div:last-child { display:none; }
    section > div:first-child { padding: 60px 32px !important; }
  }
  @media(max-width:600px) {
    section > div:first-child { padding: 48px 20px 56px !important; }
    .hero-title { font-size: clamp(28px, 9vw, 42px) !important; }
    .hero-buttons { flex-direction: column; }
    .hero-buttons a { text-align: center; width: 100%; justify-content: center; }
    section > div:first-child p { max-width: 100% !important; }
    section > div:first-child > div:last-child > div {
      padding: 14px 16px !important;
      flex: 1 1 calc(33% - 1px);
      min-width: 0;
    }
  }
</style>

<script>
  /* Counter animation */
  function animateCounter(el: Element, target: number) {
    const dur = 1400;
    const t0  = performance.now();
    (function tick(now: number) {
      const p = Math.min((now - t0) / dur, 1);
      const e = 1 - Math.pow(1 - p, 3);
      el.textContent = String(Math.round(e * target));
      if (p < 1) requestAnimationFrame(tick);
    })(t0);
  }
  const cObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.count-num').forEach(el => {
          animateCounter(el, parseInt((el as HTMLElement).dataset.target ?? '0'));
        });
        cObs.unobserve(e.target);
      }
    });
  }, { threshold: .5 });
  document.querySelectorAll('[data-target]').forEach(el =>
    cObs.observe(el.closest('div')!)
  );
</script>
