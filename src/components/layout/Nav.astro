---
// src/components/layout/Nav.astro
import ThemeToggle from '@components/ui/ThemeToggle';

const links = [
  { href: '/#about',     label: 'O mnie'       },
  { href: '/#portfolio', label: 'Portfolio'    },
  { href: '/#process',   label: 'Proces'       },
  { href: '/#cases',     label: 'Case Studies' },
  { href: '/#contact',   label: 'Kontakt'      },
];
---

<nav id="nav" aria-label="Główna nawigacja">
  <!-- Logo -->
  <a href="/" class="nav-logo" aria-label="Kacper Stolarczyk — strona główna">
    <span class="nav-dot" aria-hidden="true"></span>
    kacper.design
  </a>

  <!-- Desktop links -->
  <div class="nav-links" role="navigation">
    {links.map(({ href, label }) => (
      <a href={href} class="nav-link">{label}</a>
    ))}
  </div>

  <!-- Right: toggle + CTA + hamburger -->
  <div class="nav-right">
    <ThemeToggle client:idle />
    <a href="/#contact" class="nav-cta">Porozmawiajmy</a>

    <!-- Hamburger button (mobile only) -->
    <button
      id="nav-burger"
      class="nav-burger"
      aria-label="Otwórz menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
    </button>
  </div>
</nav>

<!-- Mobile drawer -->
<div id="nav-overlay" class="nav-overlay" aria-hidden="true"></div>
<div id="nav-drawer" class="nav-drawer" role="dialog" aria-modal="true" aria-label="Menu mobilne">
  <div class="drawer-header">
    <a href="/" class="nav-logo">
      <span class="nav-dot" aria-hidden="true"></span>
      kacper.design
    </a>
    <button id="nav-close" class="nav-close" aria-label="Zamknij menu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <nav class="drawer-links">
    {links.map(({ href, label }, i) => (
      <a href={href} class="drawer-link" style={`--i:${i}`} data-drawer-link>
        <span class="drawer-link-num">0{i + 1}</span>
        {label}
        <svg class="drawer-link-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </a>
    ))}
  </nav>

  <div class="drawer-footer">
    <a href="/#contact" class="drawer-cta" data-drawer-link>Porozmawiajmy →</a>
  </div>
</div>

<style>
  /* ── NAV BASE ── */
  #nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 500;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 56px; height: 60px;
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(16px);
    transition: background .3s;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 var(--accent-glow); }
    50%       { box-shadow: 0 0 0 8px transparent; }
  }

  .nav-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent); flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  .nav-logo {
    font-family: var(--font-display); font-weight: 800; font-size: 15px;
    letter-spacing: -.02em; display: flex; align-items: center; gap: 8px;
    color: var(--fg);
  }

  /* ── DESKTOP LINKS ── */
  .nav-links {
    display: flex; gap: 36px; align-items: center;
  }

  .nav-link {
    font-size: 12px; letter-spacing: .06em;
    color: var(--fg-60); transition: color .2s; position: relative;
  }
  .nav-link::after {
    content: ''; position: absolute; bottom: -4px; left: 0; right: 0;
    height: 1px; background: var(--accent);
    transform: scaleX(0); transform-origin: left; transition: transform 0.25s;
  }
  .nav-link:hover { color: var(--fg); }
  .nav-link:hover::after { transform: scaleX(1); }

  /* ── RIGHT SIDE ── */
  .nav-right {
    display: flex; align-items: center; gap: 12px;
  }

  .nav-cta {
    font-family: var(--font-display); font-weight: 700;
    font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
    padding: 9px 22px; border: 1px solid var(--accent); color: var(--accent);
    transition: background .2s, color .2s;
  }
  .nav-cta:hover { background: var(--accent); color: #000; }

  /* ── HAMBURGER ── */
  .nav-burger {
    display: none;
    flex-direction: column; justify-content: center; align-items: center;
    gap: 5px; width: 40px; height: 40px;
    background: none; border: none; padding: 0;
    cursor: none;
  }
  .burger-bar {
    display: block; width: 22px; height: 1.5px;
    background: var(--fg); border-radius: 2px;
    transition: transform .3s, opacity .3s;
    transform-origin: center;
  }
  .nav-burger[aria-expanded="true"] .burger-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] .burger-bar:nth-child(2) {
    opacity: 0; transform: scaleX(0);
  }
  .nav-burger[aria-expanded="true"] .burger-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── OVERLAY ── */
  .nav-overlay {
    display: none;
    position: fixed; inset: 0; z-index: 598;
    background: rgba(0,0,0,.4);
    backdrop-filter: blur(2px);
    opacity: 0; transition: opacity .3s;
  }
  .nav-overlay.open { opacity: 1; }

  /* ── DRAWER ── */
  .nav-drawer {
    position: fixed; top: 0; right: 0; bottom: 0; z-index: 599;
    width: min(320px, 85vw);
    background: var(--bg);
    border-left: 1px solid var(--border);
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(.4,0,.2,1);
    will-change: transform;
  }
  .nav-drawer.open { transform: translateX(0); }

  .drawer-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 24px; height: 60px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .nav-close {
    width: 36px; height: 36px; border: 1px solid var(--border);
    background: none; display: flex; align-items: center; justify-content: center;
    color: var(--fg-60); transition: color .2s, border-color .2s;
    cursor: none;
  }
  .nav-close:hover { color: var(--fg); border-color: var(--fg-60); }

  .drawer-links {
    flex: 1; display: flex; flex-direction: column;
    padding: 24px 0; overflow-y: auto;
  }

  .drawer-link {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 24px;
    font-family: var(--font-display); font-weight: 600; font-size: 16px;
    color: var(--fg-60); letter-spacing: -.01em;
    border-bottom: 1px solid var(--border);
    transition: color .2s, background .2s;
    opacity: 0; transform: translateX(16px);
  }
  .nav-drawer.open .drawer-link {
    animation: drawerLinkIn .4s cubic-bezier(.4,0,.2,1) forwards;
    animation-delay: calc(var(--i) * 60ms + 150ms);
  }
  @keyframes drawerLinkIn {
    to { opacity: 1; transform: translateX(0); }
  }

  .drawer-link:hover { color: var(--fg); background: var(--border); }
  .drawer-link-num {
    font-size: 9px; letter-spacing: .18em; color: var(--accent);
    font-weight: 400; width: 20px; flex-shrink: 0;
  }
  .drawer-link-arrow {
    margin-left: auto; color: var(--fg-60); flex-shrink: 0;
    transition: transform .2s;
  }
  .drawer-link:hover .drawer-link-arrow { transform: translateX(4px); }

  .drawer-footer {
    padding: 24px; border-top: 1px solid var(--border); flex-shrink: 0;
  }
  .drawer-cta {
    display: block; text-align: center;
    font-family: var(--font-display); font-weight: 700;
    font-size: 12px; letter-spacing: .14em; text-transform: uppercase;
    padding: 14px; border: 1px solid var(--accent); color: var(--accent);
    transition: background .2s, color .2s;
  }
  .drawer-cta:hover { background: var(--accent); color: #000; }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    #nav { padding: 0 20px; }
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .nav-burger { display: flex; }
  }

  @media (max-width: 480px) {
    #nav { padding: 0 16px; }
  }

  /* ── LIGHT SKIN — jasne hero (np. AutoClub) ── */
  #nav[data-skin="light"] .nav-logo  { color: #1E293B; }
  #nav[data-skin="light"] .nav-dot   { background: #2563EB; }
  #nav[data-skin="light"] .nav-link  { color: #64748B; }
  #nav[data-skin="light"] .nav-link:hover { color: #1E293B; }
  #nav[data-skin="light"] .nav-cta   { border-color: #2563EB; color: #2563EB; }
  #nav[data-skin="light"] .nav-cta:hover { background: #2563EB; color: #fff; }
  #nav[data-skin="light"] .burger-bar { background: #1E293B; }

  /* ── CSS fallback — działa bez JS, od razu przy renderze ── */
  body[data-nav-theme="light"] #nav { background: rgba(248,250,252,.85); border-bottom-color: transparent; }
  body[data-nav-theme="light"] #nav .nav-logo  { color: #1E293B; }
  body[data-nav-theme="light"] #nav .nav-dot   { background: #2563EB; }
  body[data-nav-theme="light"] #nav .nav-link  { color: #64748B; }
  body[data-nav-theme="light"] #nav .nav-link:hover { color: #1E293B; }
  body[data-nav-theme="light"] #nav .nav-cta   { border-color: #2563EB; color: #2563EB; }
  body[data-nav-theme="light"] #nav .nav-cta:hover { background: #2563EB; color: #fff; }
  body[data-nav-theme="light"] #nav .burger-bar { background: #1E293B; }
</style>

<script>
  /* ── Scroll nav background ── */
  const nav = document.getElementById('nav')!;

  function updateNav() {
    const isLight     = document.documentElement.dataset.theme === 'light';
    const heroIsLight = document.body.dataset.navTheme === 'light';

    if (heroIsLight) {
      // Strona z jasnym hero (np. AutoClub) — nav zawsze jasny
      nav.style.background = scrollY > 60
        ? 'rgba(248,250,252,.98)'
        : 'rgba(248,250,252,.85)';
      nav.style.borderBottomColor = scrollY > 60 ? 'rgba(37,99,235,0.12)' : 'transparent';
      nav.dataset.skin = 'light';
    } else {
      // Strona z ciemnym hero (główna, QL&Joy, MedTrack itd.)
      nav.style.background = scrollY > 60
        ? (isLight ? 'rgba(240,242,245,.98)' : 'rgba(26,29,33,.97)')
        : (isLight ? 'rgba(240,242,245,.90)' : 'rgba(26,29,33,.88)');
      nav.style.borderBottomColor = '';
      nav.dataset.skin = isLight ? 'light' : 'dark';
    }
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  document.addEventListener('themechange', updateNav);
  updateNav(); // ustaw skórkę od razu przy załadowaniu

  /* ── Mobile drawer ── */
  const burger  = document.getElementById('nav-burger')!;
  const drawer  = document.getElementById('nav-drawer')!;
  const overlay = document.getElementById('nav-overlay')!;
  const closeBtn = document.getElementById('nav-close')!;

  function openDrawer() {
    drawer.classList.add('open');
    overlay.classList.add('open');
    overlay.style.display = 'block';
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer.classList.remove('open');
    overlay.classList.remove('open');
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    setTimeout(() => { overlay.style.display = 'none'; }, 300);
  }

  burger.addEventListener('click', () => {
    burger.getAttribute('aria-expanded') === 'true' ? closeDrawer() : openDrawer();
  });
  closeBtn.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);

  document.querySelectorAll('[data-drawer-link]').forEach(link => {
    link.addEventListener('click', closeDrawer);
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeDrawer();
  });

  document.addEventListener('astro:after-swap', () => {
    closeDrawer();
    updateNav();
  });
</script>
